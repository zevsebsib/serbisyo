rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isAdminStaff() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.role == 'admin';
    }

    function isAnyAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    function adminDepartmentId() {
      return isAnyAdmin() ?
        (
          get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.departmentId != null
            ? get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.departmentId
            : (
              get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.DepartmentId != null
                ? get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.DepartmentId
                : ''
            )
        ) :
        '';
    }

    function adminDepartmentName() {
      return isAnyAdmin() ?
        (
          get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.department != null
            ? get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.department
            : (
              get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.Department != null
                ? get(/databases/$(database)/documents/admin/$(request.auth.uid)).data.Department
                : ''
            )
        ) :
        '';
    }

    function matchesDepartmentCategory(serviceData) {
      return
        (adminDepartmentName() == 'City Administration Office' && serviceData.categoryId == 'mayor') ||
        (adminDepartmentName() == 'Office of the City Civil Registrar' && serviceData.categoryId == 'civil') ||
        (adminDepartmentName() == 'Office of the City Community Affairs' && serviceData.categoryId == 'community');
    }

    function canManageService(serviceData) {
      return isSuperAdmin() || (
        isAdminStaff() &&
        (
          serviceData.departmentId == adminDepartmentId() ||
          serviceData.department == adminDepartmentName() ||
          matchesDepartmentCategory(serviceData)
        )
      );
    }

    function isStatusOnlyServiceUpdate() {
      return request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['isActive', 'updatedAt']);
    }

    // ── Admin collection ───────────────────────────────────────────
    match /admin/{adminId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (request.auth.uid == adminId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Users (citizens) ──────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn() &&
        (request.auth.uid == userId || isAnyAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (request.auth.uid == userId || isAnyAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Requests ──────────────────────────────────────────────────
    match /requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin() ||
        isAnyAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAnyAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read:  if isSignedIn() &&
        (request.auth.uid == userId || isAnyAdmin());
      allow write: if isSignedIn() &&
        (request.auth.uid == userId || isAnyAdmin());
    }

    // ── Departments ───────────────────────────────────────────────
    match /departments/{deptId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ── Services (NEW) ────────────────────────────────────────────
    match /services/{serviceId} {
      allow read:   if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
        (isAnyAdmin() && isStatusOnlyServiceUpdate()) ||
        (isAdminStaff() &&
          canManageService(resource.data) &&
          isStatusOnlyServiceUpdate());
      allow delete: if isSuperAdmin();
    }

    // ── Notification templates ────────────────────────────────────
    match /notification_templates/{templateId} {
      allow read:  if isAnyAdmin();
      allow write: if isSuperAdmin();
    }

    // ── Categories ────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ── Announcements ─────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read:  if isSignedIn();
      allow write: if isAnyAdmin();
    }
  }
}